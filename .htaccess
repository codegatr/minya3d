Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # HTTPS yönlendirmesi (canlıda aktif et)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ── SEO: İl sayfaları ({il-slug}-3d-baski) ──────────────────────────
    RewriteRule ^([a-z]+)-3d-baski/?$ sehir.php?sehir=$1 [L,QSA]

    # ── SEO: Konya ilçe sayfaları (konya-{ilce}-3d-baski) ───────────────
    RewriteRule ^konya-([a-z]+)-3d-baski/?$ ilce.php?sehir_ilce=konya-$1 [L,QSA]

    # ── Ürün detay: /urun/slug ───────────────────────────────────────────
    RewriteRule ^urun/([a-z0-9-]+)/?$  urun.php?slug=$1 [L,QSA]

    # ── Kategori: /kategori/slug ─────────────────────────────────────────
    RewriteRule ^kategori/([a-z0-9-]+)/?$ urunler.php?kat=$1 [L,QSA]

    # ── Blog detay: /blog/slug ───────────────────────────────────────────
    RewriteRule ^blog/([a-z0-9-]+)/?$ blog-detay.php?slug=$1 [L,QSA]

    # ── Sitemap ──────────────────────────────────────────────────────────
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

# PHP ayarları (DirectAdmin shared hosting)
<IfModule mod_php8.c>
    php_value upload_max_filesize 52M
    php_value post_max_size 52M
    php_value max_execution_time 120
    php_value memory_limit 256M
    php_value max_input_vars 3000
</IfModule>

# Hassas dosyalar
<FilesMatch "\.(sql|log|env|json|md|sh|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>
<Files "composer.json">
    Order Allow,Deny
    Deny from all
</Files>

# manifest.json hariç (güncelleme için okunabilir)
<Files "manifest.json">
    Order Allow,Deny
    Allow from all
</Files>

# Gzip sıkıştırma
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json text/xml
</IfModule>

# Önbellek (statik dosyalar)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp   "access plus 1 month"
    ExpiresByType image/png    "access plus 1 month"
    ExpiresByType image/jpeg   "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 week"
    ExpiresByType text/css     "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Backups ve tmp klasörüne erişim yok
<IfModule mod_rewrite.c>
    RewriteRule ^backups/ - [F,L]
    RewriteRule ^tmp/ - [F,L]
</IfModule>
